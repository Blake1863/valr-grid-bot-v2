# VALR Grid Bot v2 — Environment Variables
# 
# Copy this file to .env and fill in your actual API credentials
# Make sure .env is in your .gitignore to prevent accidental commits
#
# DO NOT commit your .env file with real credentials to version control!

# VALR API Credentials
# Get these from your VALR account settings at https://app.valr.com/settings/api
# API Key: Used for authentication headers
VALR_API_KEY=your_api_key_here

# API Secret: Used for request signing (HMAC-SHA512)
# Keep this confidential - treat it like a password
VALR_API_SECRET=your_api_secret_here

# Optional: Subaccount ID
# Leave empty if you want to trade on your main account
# VALR_SUBACCOUNT_ID=
